generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Models

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  encryptedDetails String?

  role          String    @default("OFFICER")
  agency        String?
  department    String?
  clearanceLevel Int      @default(1)
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  incidents     Incident[] @relation("ReportedIncidents")
  intelligence  Intelligence[]
  auditLogs     AuditLog[]
}

// UserRole enum removed for SQLite compatibility

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?

  access_token       String?

  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?

  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application Models

model Incident {
  id          String         @id @default(cuid())
  title       String
  description String
  type        String         @default("GENERAL")
  priority    String         @default("MEDIUM")
  status      String         @default("OPEN")
  severity    String         @default("MEDIUM") // Standardize with 'severity' for some UI parts
  location    String?
  latitude    Float?
  longitude   Float?
  county      String?
  targetAsset String?
  attackVector String?
  indicators  String?       

  
  encryptedDetails String?

  reportedBy  String?
  reporter    User?          @relation("ReportedIncidents", fields: [reportedBy], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  detectedAt  DateTime       @default(now())
  resolvedAt  DateTime?

  threats     Threat[]
  responses   Response[]
}

model Threat {
  id          String   @id @default(cuid())
  name        String
  type        String
  severity    String
  source      String?
  targetSector String?
  confidence  Float    @default(0.0)
  mitreId     String?
  description String?
  indicators  String? 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  incidents   Incident[]
}

model Response {
  id          String   @id @default(cuid())
  type        String
  status      String
  incidentId  String
  incident    Incident @relation(fields: [incidentId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  resource    String
  resourceId  String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  details     String? 

  ipAddress   String?
  userAgent   String?
  hash        String   @unique
  previousHash String?
  createdAt   DateTime @default(now())
}

// IncidentStatus enum removed for SQLite compatibility

// Priority enum removed for SQLite compatibility

model Intelligence {
  id          String   @id @default(cuid())
  title       String
  content     String
  source      String
  classification String @default("CONFIDENTIAL")
  createdBy   String 
  author      User     @relation(fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  expiresAt   DateTime?
}

// Classification enum removed for SQLite compatibility

model SurveillanceFeed {
  id          String   @id @default(cuid())
  location    String
  type        String
  status      String   @default("ACTIVE")
  latitude    Float?
  longitude   Float?
  streamUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
